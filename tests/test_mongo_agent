def get_postgres_credentials():
    try:
        result = subprocess.run(['podman', 'inspect', 'postgresdb'],
                              capture_output=True, text=True)
        if result.returncode == 0:
            container_info = json.loads(result.stdout)[0]
            env_vars = container_info.get('Config', {}).get('Env', [])

            credentials = {'user': 'postgres', 'password': 'postgres'}

            for env in env_vars:
                if env.startswith('POSTGRES_PASSWORD='):
                    credentials['password'] = env.split('=', 1)[1]
                elif env.startswith('POSTGRES_USER='):
                    credentials['user'] = env.split('=', 1)[1]

            return credentials
    except:
        pass

    return {'user': 'postgres', 'password': 'postgres'}

