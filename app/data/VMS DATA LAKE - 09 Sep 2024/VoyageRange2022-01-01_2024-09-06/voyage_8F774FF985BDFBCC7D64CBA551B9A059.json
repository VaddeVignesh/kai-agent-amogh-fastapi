oyageEEOI":7.140985457996301000,"voyageAER":4.284606058136357000,"voyageSOxMt":9.638600000000002000,"voyageSOx":0.019888475841946293,"voyageNOxMt":110.610000000000010000,"voyageNOx":0.228234838345577100,"euEtsDetails":null,"legEmissionsDetails":[{"portName":"Corpus Christi","displayOrder":2,"co2":126.515439252159980000,"eeoi":7.333109810085849000,"aer":4.399881067127816000,"soxMt":0.078924166720000000,"sox":0.004574616225880131,"noxMt":3.946208335999999800,"nox":0.228730811294006550,"euEtsDetails":null},{"portName":"Offshore Galveston No.1 (Tsa)","displayOrder":1,"co2":125.796760747840000000,"eeoi":18.408480860709734000,"aer":11.045126625844610000,"soxMt":0.078475833280000000,"sox":0.011483768472058474,"noxMt":3.923791664000000300,"nox":0.574188423602923800,"euEtsDetails":null},{"portName":"Texas City","displayOrder":0,"co2":0.000000000000000000,"eeoi":0.000000000000000000,"aer":0.000000000000000000,"soxMt":0.000000000000000000,"sox":0.000000000000000000,"noxMt":0.000000000000000000,"nox":0.000000000000000000,"euEtsDetails":null},{"portName":"Tranmere","displayOrder":3,"co2":3208.440800000000000000,"eeoi":6.966599994707894000,"aer":4.179974419148805000,"soxMt":9.481200000000001000,"sox":0.020586861964174155,"noxMt":102.740000000000010000,"nox":0.223082963991820950,"euEtsDetails":null}]},"remarkList":[{"modifiedDate":"2021-05-27T15:43:09.207","modifiedByFull":"Wright, Bryan","remark":"Operator comments: \n\t\n\tA bit of an interesting one. VMS routed her through the ECA for most of the voyage from Corpus Christi to Tranmere, UK. The actual route was outside of the ECA on VLSFO consumption \u2013 this typically would help the intermediate TCE as we burn the less expensive VLSFO. Oddly enough, the average price of VLSFO on board is $130/mt higher than the MGO on board which was taken in October 2020 at $328/mt, right before the prices came way up. This, as well as an additional 2mt per day consumption due to hull growth resulted in a $120k increase in bunker cost. Other changes as follows.\n-\tCorpus Christi ~ $60k less than expected\n-\tDischarge in Tranmere instead of Rotterdam decreases freight by $70k / port costs increase $23k / laden passage one day shorter\n-\tPilots in Tranmere refused to board due to the arrangement of pilot ladder, resulting in a delay of one day until an agreement could be reached. We were put on notice by charterers for this time, but the vessel completed load and discharge within the allotted laytime and there is nil demurrage to claim either way.\n-\tAnother case of heavy sludge on US VLSFO. With TSP is exactly at the limit, this fuel is technically on spec. The crew has so far been able to burn it with manual cleaning of purifiers every two hours. Good for ops to continue pushing owners for timely sampling and testing of bunkers taken in USG."}],"offhireList":[],"tcNumber":null,"tcOutIdEncrypted":null,"tcReletDetail":null}