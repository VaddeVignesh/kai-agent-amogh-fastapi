cted"},{"modifiedDate":"2022-08-10T14:51:02.973","modifiedByFull":"Ervasti, Josh","remark":"more LSGO at Pascagoula than expected"},{"modifiedDate":"2022-08-09T20:48:53.95","modifiedByFull":"Eisemann, Jason","remark":"tce increase due to updated estimated demurrage"}],"offhireList":[],"tcNumber":null,"tcOutIdEncrypted":null,"tcReletDetail":null}