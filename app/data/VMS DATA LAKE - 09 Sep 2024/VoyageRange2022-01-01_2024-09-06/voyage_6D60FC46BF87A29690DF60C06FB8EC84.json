6310337000,"soxMt":0.265060000000000000,"sox":0.135447250766857960,"noxMt":2.653000000000000500,"nox":1.355698922072263700,"euEtsDetails":null},{"portName":"Esmeraldas","displayOrder":0,"co2":0.000000000000000000,"eeoi":0.000000000000000000,"aer":0.000000000000000000,"soxMt":0.000000000000000000,"sox":0.000000000000000000,"noxMt":0.000000000000000000,"nox":0.000000000000000000,"euEtsDetails":null},{"portName":"Port Angeles","displayOrder":5,"co2":278.502460000000000000,"eeoi":10.743427248876216000,"aer":6.449897463052859000,"soxMt":0.173980000000000020,"sox":0.006711400225188260,"noxMt":8.687000000000001000,"nox":0.335107102863607400,"euEtsDetails":null}]},"remarkList":[{"modifiedDate":"2022-04-06T16:20:26.953","modifiedByFull":"Fitzgerald, Ethan","remark":"Stockton FDA 57k greater than initial due appropriate allocation of costs (dockage and additional mooring/unmooring costs for Stena) - voyage financials should finally be closed over a year later...."},{"modifiedDate":"2021-10-05T20:47:13.64","modifiedByFull":"Ervasti, Josh","remark":"FDA\u0027s came in $50k cheaper - updated by Alex Webb"},{"modifiedDate":"2021-03-17T16:25:10.26","modifiedByFull":"Webb, Alex","remark":"Difference:  Vessel was fixed for Loading Corinto / San Jose with a 3rd Load Port option $45,000.00 which was Acajutla. It was commercially agreed that the Port rotation didn\u2019t have to be south to North in order to extend laycan. Rotation ended being North to south which added about 15 hours to laden passage and about 10 hrs to ballast leg. Overall bunkers expenses increased by $201,249.38. Firstly due to hull fouling and bad weather which caused delays and over consumption of approx. 4.5 mt/day (excluding heating), Instructed speed 13 knts / actual 11 knts. Secondly cargo heating was average 7.0 mt/day as Molasses had to be kept between 44-46 deg c throughout in cold waters, cargo heating cost was around 50,3k usd VS estimated 20k. The vessel\u2019s small LSMGO tanks and higher than expected consumption forced us to stem expensive LSMGO bunkers (934 mtd in Acajutla, 688 mtd in Stockton). Voyage LSGO estimated at 414.77 USD vs actual 626.21 USD. We did try to minimize the outcome by bunkering minimum in Acajutla and min in Stockton, hence bunkering in both. Screw pumps with MariFlex were cheaper then expected around 30K usd vs estimated at 70k usd however still waiting on final invoice. Total days are 9.15 more than expected, 3.21 days more during passage (due to bad weather \u002B hull fouling \u002B change of rotation) and 5.93 days in port due to slow rate of discharge and waiting on Pilots which allowed for 09:04 Hrs ($7,306.27 usd) of demurrage. Port Cost was approx 12k usd less than estimated (excluding Acajutla port cost as it was not in initial estimate). There was a squeezing Bonus of 4,800 usd for the crew (400 usd/tank for 12 tanks). Lastly we did get some overage of 4,011.87 MT which increased the freight by 71,210.6925 USD (overage above 26kt to be 50% of rate). We looked for hull cleaning options in Pacific NW but nothing available. Currently attempting to organize hull scrub at next disport."},{"modifiedDate":"2020-12-15T15:55:07.41","modifiedByFull":"Hebel, Nicolai","remark":""}],"offhireList":[],"tcNumber":null,"tcOutIdEncrypted":null,"tcReletDetail":null}