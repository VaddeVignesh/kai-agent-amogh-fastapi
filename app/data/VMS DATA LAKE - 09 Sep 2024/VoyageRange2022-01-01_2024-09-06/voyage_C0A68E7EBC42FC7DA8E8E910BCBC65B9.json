umptionCost":332.00000000000000000,"bunkerGradeName":"LSGO","consCost":132.80000000000000000,"consTotal":0.40000000000000000,"displayOrder":6,"refillPrice":600.00000000000000000,"remainderConsCost":0.00000000000000000,"totalCost":132.80000000000000000}],"emissionsDetails":{"voyageCIIBand":null,"voyageCO2":null,"voyageEEOI":null,"voyageAER":null,"voyageSOxMt":null,"voyageSOx":null,"voyageNOxMt":null,"voyageNOx":null,"euEtsDetails":null,"legEmissionsDetails":[]},"remarkList":[{"modifiedDate":"2022-03-30T16:35:42.813","modifiedByFull":"Wright, Bryan","remark":"TCE Increase \u002B$3.8k with Suez Canal Rebate applied"},{"modifiedDate":"2021-08-03T19:22:04.01","modifiedByFull":"Wright, Bryan","remark":"Due to weather delays on the previous voyage, only part of the hull had been cleaned and she remained heavily fouled. We received approval from charterers to go ahead with hull cleaning after loading with the agreement we would make up any lost time. After a few hours the hull cleaning team departed and never came back (Encompass Marine/Seatec for future reference). Despite the incomplete job, we were obligated to increase speed and make up this time. The additional bunkers were billed back to owners. \n\tWith bad weather on the ballast passage we did not have time to take bunkers prior to loading. We stopped in Statia on the laden passage for 15 hours, and were again obligated to make up this time. The above resulted in the vessel making max safe speed with a fouled hull from Puerto Bahia to Port Said. Additionally, VLSFO prices were $22/mt higher than estimated. \n\tLoading operations took 3 days longer than expected allowing us to bill $74k (~3 days @ $25kpd). We were not aware of the hourly dockage rate increase after 48 hours, which essentially nullifies our demurrage and then some. I\u2019ve explained further on this below. In short, Puerto Bahia port costs increased from $115k expected to $180k actual. \n\tWith Trafi running late for their discharge window, routing was amended to Suez Canal rather than COGH. This results in additional port costs of $350k and guards\u002Binsurance for ~ $10k, but saves about 6-7 days and increases freight $440k. Not included in the above result is the expected Suez Canal rebate of 75% on tolls valued at approx. $235k for this voyage.\n\tVadinar port costs are ~ $20k less than estimated."}],"offhireList":[{"id":172800,"dateStartUtc":null,"dateEndUtc":null,"days":0.0,"displayOrder":0,"offhireReason":"Other","remark":"Bunkers to speed up to make up hull cleaning time","offhireBunkerList":[{"id":6572,"gradeName":"LSBF","quantity":92.4,"price":483.36,"displayOrder":1}]}],"tcNumber":null,"tcOutIdEncrypted":null,"tcReletDetail":null}